    "app:AppSettings:SERVICE_BUS_TRANSFER_SUBSCRIPTION": "transfer",

    "app:AppSettings:WRITE_SOURCE_DEBIT": "true",
    "app:AppSettings:WRITE_DESTINATION_CREDIT": "true",

